.DS_Store
Thumbs.db
ehthumbs.db

# Editor directories and files
.idea/
*.iml
*.ipr
*.iws
# Uncomment to ignore VS Code workspace settings if you don't want to commit them
# .vscode/

# Dart/Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
/build/
/coverage/
**/doc/api/

# Flutter Xcode / iOS
**/ios/Flutter/.last_build_id
**/Flutter/ephemeral/
**/Generated.xcconfig
**/Flutter/Flutter.framework

# Android
/android/.gradle/
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/captures/
/.gradle
/local.properties
key.properties
*.keystore
*.jks

# Native build artifacts
.cxx/

# IDE / build caches
/.gradle/
/build/

# Keys, secrets and environment files (keep out of repo)
.env
*.env
key.properties
google-services.json

# Crash symbol files and maps
app.*.symbols
app.*.map.json

# Temporary files
*.log
*.tmp
*.temp
*.swp
*.lock

# Generated files and folders (ignore generated sources and intermediates)
**/generated/
**/gen/
**/Generated/
**/build/generated/
**/*/generated/
*.g.dart
*.pb.dart
*.pbjson.dart
*.pbenum.dart
*.freezed.dart
*.template.dart
*.template.dart.js
*.snapshot
*.flutter-plugins
*.flutter-plugins-dependencies

# Node / JS
node_modules/

# Test output
coverage/

# Misc
.history
.vagrant/
.cache

# Keep project metadata files (do NOT ignore these):
# - pubspec.yaml, pubspec.lock (apps should commit pubspec.lock),
# - Instruction.md is a project file and should be tracked.

